PORT=5000
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/hostel_db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
