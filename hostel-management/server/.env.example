# Nodemailer (Gmail example)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your@gmail.com"
EMAIL_PASS="your_app_password"
EMAIL_FROM="Hostel Management <your@gmail.com>"

# Frontend URL (for CORS)
CLIENT_URL="http://localhost:5173"
